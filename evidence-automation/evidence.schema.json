{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/oindeed/grc-engineering-capstone/evidence-automation/evidence.schema.json",
  "title": "Control evidence document",
  "type": "object",
  "required": ["schema_version", "collected_at", "collector", "source", "target", "controls"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "collected_at": {"type": "string", "format": "date-time"},
    "collector": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"type": "string"},
        "version": {"type": "string"}
      }
    },
    "source": {"type": "string"},
    "target": {
      "type": "object",
      "required": ["type", "name"],
      "properties": {
        "type": {"type": "string"},
        "name": {"type": "string"}
      }
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["control_id", "status", "expected", "observed"],
        "properties": {
          "control_id": {"type": "string", "pattern": "^[A-Z]{2}-[0-9]+(/[A-Z]{2}-[0-9]+)*$"},
          "status": {"enum": ["satisfied", "not-satisfied", "not-applicable"]},
          "expected": {},
          "observed": {}
        }
      }
    }
  }
}
